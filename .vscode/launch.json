{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Attach (tsx watch)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "cwd": "${workspaceFolder}/backend",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "preLaunchTask": "backend:dev (inspect)"
    },
    {
      "name": "Frontend: Chrome (Vite)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "frontend:dev"
    },
    {
      "name": "Backend: Debug Jest",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "backend",
        "jest",
        "--runInBand",
        "--watchAll=false"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Frontend: Debug Vitest",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "frontend",
        "vitest",
        "run",
        "--no-file-parallelism"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Backend: Jest Watch (Terminal Debug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "yarn workspace backend test --watch"
    },
    {
      "name": "Frontend: Vitest Watch (Terminal Debug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "yarn workspace frontend test:watch"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend",
      "configurations": [
        "Backend: Attach (tsx watch)",
        "Frontend: Chrome (Vite)"
      ],
      "stopAll": true
    },
    {
      "name": "Test Debug: Backend + Frontend",
      "configurations": [
        "Backend: Debug Jest",
        "Frontend: Debug Vitest"
      ],
      "stopAll": true
    }
  ]
}