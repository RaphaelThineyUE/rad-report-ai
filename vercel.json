{
  "buildCommand": "yarn workspace backend build && yarn workspace frontend build",
  "outputDirectory": "frontend/dist",
  "installCommand": "yarn install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
