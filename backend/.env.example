# ─────────────────────────────────────────────
# Backend environment template
# Copy to .env.local and fill in real values
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
# Port the Express server listens on
PORT=3001

# Runtime environment; controls CORS rules, error verbosity, and Sentry tagging
NODE_ENV=development

# Full URL of the frontend app; used for CORS allow-list and OAuth redirect targets
FRONTEND_URL=http://localhost:5173

# ── Supabase ──────────────────────────────────
# Project API URL — found in Supabase dashboard → Settings → API
SUPABASE_URL=<your-supabase-url>

# Service-role key — bypasses RLS; used only for Storage uploads and admin writes
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Anon key — attached to user-scoped queries so RLS enforces row ownership
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Anthropic / Claude ────────────────────────
# Secret API key from console.anthropic.com — never expose to the frontend
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Claude model ID used by claudeService.ts (default: claude-sonnet-4-6 when unset)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── File Upload ───────────────────────────────
# Maximum PDF upload size in megabytes enforced by multer
MAX_FILE_SIZE_MB=40

# Run background report worker inside backend server process (`false` if using separate worker)
REPORT_WORKER_INLINE=true

# Milliseconds worker waits before polling for next queued report
REPORT_WORKER_POLL_MS=2000

# Seconds job lease stays owned by worker before another worker may reclaim it
REPORT_WORKER_LEASE_SECONDS=900

# Supabase Storage bucket name for radiology report PDFs
STORAGE_BUCKET=reports

# ── Sentry ────────────────────────────────────
# Data source name from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=<your-sentry-dsn>

# Fraction of transactions to capture as performance traces (0.0 – 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Fraction of traced transactions to include CPU profiles (0.0 – 1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.1

#OCR Space API key
OCRSPACE_API_KEY=<your-ocr-space-api-key>



# ─────────────────────────────────────────────
# Variable usage map
# ─────────────────────────────────────────────
# Variable                    │ Used in
# ────────────────────────────┼──────────────────────────────────────────────────
# PORT                        │ backend/src/index.ts
# NODE_ENV                    │ backend/src/app.ts, backend/src/utils/sentry.ts
# FRONTEND_URL                │ backend/src/app.ts, backend/src/controllers/authController.ts
# SUPABASE_URL                │ backend/src/services/supabaseClient.ts
# SUPABASE_SERVICE_ROLE_KEY   │ backend/src/services/supabaseClient.ts
# SUPABASE_ANON_KEY           │ backend/src/services/supabaseClient.ts
# ANTHROPIC_API_KEY           │ backend/src/services/claudeService.ts
# ANTHROPIC_MODEL             │ backend/src/services/claudeService.ts
# MAX_FILE_SIZE_MB            │ backend/src/routes/reports.ts
# STORAGE_BUCKET              │ backend/src/controllers/reportController.ts
# SENTRY_DSN                  │ backend/src/utils/sentry.ts
# SENTRY_TRACES_SAMPLE_RATE   │ backend/src/utils/sentry.ts
# SENTRY_PROFILES_SAMPLE_RATE │ backend/src/utils/sentry.ts
# ─────────────────────────────────────────────
