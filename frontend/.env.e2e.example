# ─────────────────────────────────────────────
# E2E test credentials template
# Copy to .env.e2e.local and fill in a real
# test account (not a production account).
# ─────────────────────────────────────────────

# ── Test Account ──────────────────────────────
# Email address of the dedicated Supabase test user
E2E_TEST_EMAIL=<your-e2e-test-email>

# Password for the test user account above
E2E_TEST_PASSWORD=<your-e2e-test-password>

# ─────────────────────────────────────────────
# Variable usage map
# ─────────────────────────────────────────────
# Variable          │ Used in
# ──────────────────┼──────────────────────────────────────────────────
# E2E_TEST_EMAIL    │ frontend/tests/auth.setup.ts
#                   │ frontend/tests/auth-flow.spec.ts
#                   │ frontend/tests/uber-test.spec.ts
# E2E_TEST_PASSWORD │ frontend/tests/auth.setup.ts
#                   │ frontend/tests/auth-flow.spec.ts
#                   │ frontend/tests/uber-test.spec.ts
# ─────────────────────────────────────────────
