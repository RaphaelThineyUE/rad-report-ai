# ─────────────────────────────────────────────
# Frontend environment template
# Copy to .env.local and fill in real values
# ─────────────────────────────────────────────

# ── API ───────────────────────────────────────
# Base URL for the Express backend; injected into the Axios client
VITE_API_URL=http://localhost:3001

# ── Supabase ──────────────────────────────────
# Project API URL — must match the backend's SUPABASE_URL
VITE_SUPABASE_URL=<your-supabase-url>

# Public anon key — safe to expose in the browser; RLS enforces data access
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Sentry ────────────────────────────────────
# Data source name from sentry.io → Project → Settings → Client Keys
VITE_SENTRY_DSN=<your-sentry-dsn>

# Fraction of transactions to capture as performance traces (0.0 – 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Sentry Source Maps (build-time only) ─────
# Used by the Sentry Vite plugin to upload source maps on production builds.
# Uncomment and fill in when building for production.
# SENTRY_AUTH_TOKEN=<your-sentry-auth-token>
# SENTRY_ORG=<your-sentry-org-slug>
# SENTRY_PROJECT=<your-sentry-project-slug>

# ─────────────────────────────────────────────
# Variable usage map
# ─────────────────────────────────────────────
# Variable                       │ Used in
# ───────────────────────────────┼──────────────────────────────────────────────────
# VITE_API_URL                   │ frontend/src/lib/api.ts
# VITE_SUPABASE_URL              │ frontend/src/lib/supabase.ts
# VITE_SUPABASE_ANON_KEY         │ frontend/src/lib/supabase.ts
# VITE_SENTRY_DSN                │ frontend/src/utils/sentry.ts
# VITE_SENTRY_TRACES_SAMPLE_RATE │ frontend/src/utils/sentry.ts
# SENTRY_AUTH_TOKEN              │ vite.config.ts (Sentry plugin, build-time only)
# SENTRY_ORG                     │ vite.config.ts (Sentry plugin, build-time only)
# SENTRY_PROJECT                 │ vite.config.ts (Sentry plugin, build-time only)
# ─────────────────────────────────────────────
